<!DOCTYPE html>
<html lang="pt-BR">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>PrimeViz | Visualização Arquitetônica</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:'Inter',sans-serif;
background:#070707;
color:white;
overflow-x:hidden;
}

::-webkit-scrollbar{
width:8px;
}

::-webkit-scrollbar-thumb{
background:#14c9ff;
border-radius:20px;
}

header{
position:fixed;
top:0;
width:100%;
z-index:9999;
background:rgba(0,0,0,.75);
backdrop-filter:blur(20px);
border-bottom:1px solid rgba(255,255,255,.05);
}

.navbar{
max-width:1400px;
margin:auto;
padding:18px 40px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
height:65px;
width:auto;
}

.menu{
display:flex;
align-items:center;
gap:35px;
}

.menu a{
text-decoration:none;
color:white;
font-weight:500;
transition:.3s;
}

.menu a:hover{
color:#14c9ff;
}

.btn{
background:#14c9ff;
color:#000 !important;
padding:14px 28px;
border-radius:50px;
font-weight:700;
transition:.3s;
text-decoration:none;
}

.btn:hover{
transform:translateY(-3px);
box-shadow:0 15px 40px rgba(20,201,255,.25);
}

.hero{
height:100vh;
position:relative;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
overflow:hidden;
}

.hero::before{
content:"";
position:absolute;
inset:0;
background:
linear-gradient(
to bottom,
rgba(0,0,0,.45),
rgba(0,0,0,.8)
),
url("https://various-amber-zl8i3uxf.edgeone.app/SKYLINNE%2001.png");
background-size:cover;
background-position:center;
background-attachment:fixed;
transform:scale(1.05);
}

.hero-content{
position:relative;
z-index:2;
max-width:900px;
padding:20px;
animation:fadeUp 1s ease;
}

.hero h1{
font-size:clamp(3rem,8vw,6rem);
font-weight:900;
line-height:1;
margin-bottom:25px;
}

.hero span{
color:#14c9ff;
}

.hero p{
font-size:1.2rem;
line-height:1.8;
opacity:.85;
margin-bottom:40px;
}

.hero-buttons{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
}

section{
padding:120px 40px;
}

.container{
max-width:1400px;
margin:auto;
}

.section-title{
text-align:center;
margin-bottom:70px;
}

.section-title span{
color:#14c9ff;
text-transform:uppercase;
letter-spacing:3px;
font-size:.8rem;
font-weight:700;
}

.section-title h2{
font-size:3rem;
margin-top:10px;
}

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.service{
background:#101010;
padding:40px;
border-radius:28px;
border:1px solid rgba(255,255,255,.05);
transition:.4s;
}

.service:hover{
transform:translateY(-10px);
border-color:#14c9ff;
}

.service h3{
font-size:1.5rem;
margin-bottom:15px;
}

.service p{
color:#9f9f9f;
line-height:1.8;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
gap:25px;
}

.card{
overflow:hidden;
border-radius:30px;
background:#111;
position:relative;
cursor:pointer;
transition:.4s;
}

.card:hover{
transform:translateY(-8px);
}

.card img{
width:100%;
height:500px;
object-fit:cover;
display:block;
transition:1s;
}

.card:hover img{
transform:scale(1.08);
}

.overlay{
position:absolute;
bottom:0;
width:100%;
padding:35px;
background:linear-gradient(transparent,rgba(0,0,0,.95));
}

.overlay h3{
font-size:1.6rem;
}

.parallax{
height:60vh;
background:
linear-gradient(
rgba(0,0,0,.45),
rgba(0,0,0,.45)
),
url("https://strange-apricot-kf7xxrhj.edgeone.app/arboreum%2002.png");
background-size:cover;
background-position:center;
background-attachment:fixed;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
}

.parallax h2{
font-size:4rem;
max-width:900px;
}

.testimonials{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.testimonial{
background:#111;
padding:35px;
border-radius:24px;
border:1px solid rgba(255,255,255,.05);
}

.testimonial p{
line-height:1.8;
color:#d4d4d4;
margin-bottom:20px;
}

.testimonial h4{
color:#14c9ff;
}

.cta{
background:#14c9ff;
color:black;
padding:120px 40px;
text-align:center;
}

.cta h2{
font-size:3.5rem;
margin-bottom:20px;
font-weight:900;
}

.cta p{
max-width:700px;
margin:auto;
margin-bottom:40px;
font-size:1.1rem;
line-height:1.8;
}

.cta a{
display:inline-block;
padding:18px 40px;
background:black;
color:white;
text-decoration:none;
border-radius:50px;
font-weight:700;
}

footer{
padding:50px;
text-align:center;
border-top:1px solid rgba(255,255,255,.08);
color:#8f8f8f;
}

.reveal{
opacity:0;
transform:translateY(40px);
transition:1s;
}

.reveal.active{
opacity:1;
transform:none;
}

@keyframes fadeUp{
from{
opacity:0;
transform:translateY(40px);
}
to{
opacity:1;
transform:none;
}
}

@media(max-width:768px){

.navbar{
padding:15px 20px;
}

.menu a:not(.btn){
display:none;
}

.hero::before,
.parallax{
background-attachment:scroll;
}

.hero h1{
font-size:3rem;
}

.section-title h2{
font-size:2rem;
}

.parallax h2{
font-size:2rem;
padding:20px;
}

.cta h2{
font-size:2.2rem;
}

.gallery{
grid-template-columns:1fr;
}

.card img{
height:320px;
}

.logo{
height:50px;
}

}

</style>
</head>

